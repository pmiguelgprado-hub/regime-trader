# ============================================================================
# regime-trader — credentials.yaml.example
# Copy to credentials.yaml and fill in. credentials.yaml is gitignored.
# Prefer .env for secrets; this file is an alternative for structured config.
# ============================================================================

alpaca:
  api_key: "your_key_here"
  secret_key: "your_secret_here"
  paper: true                       # true = paper trading endpoint
  base_url: "https://paper-api.alpaca.markets"   # live: https://api.alpaca.markets
  data_url: "https://data.alpaca.markets"

alerts:
  email:
    smtp_host: "smtp.example.com"
    smtp_port: 587
    username: "alerts@example.com"
    password: "your_email_password"
    from_addr: "alerts@example.com"
    to_addrs:
      - "you@example.com"
  webhook:
    url: "https://hooks.example.com/your-webhook"
